{
  "method": "sarr_code_aggressive_prefix",
  "slm": {
    "model_path": "/path/to/local/DeepSeek-R1-Distill-Qwen-1.5B",
    "tokenizer_path": null,
    "chat_template_path": "server/template/deepseekr1.jinja",
    "device": "cuda:0",
    "dtype": "bfloat16",
    "trust_remote_code": true,
    "local_files_only": true,
    "backend": "transformers"
  },
  "llm": {
    "model_path": "/path/to/local/Qwen-or-DeepSeek-LLM-tokenizer",
    "tokenizer_path": null,
    "chat_template_path": "server/template/qwen3.jinja",
    "device": "cuda:1",
    "dtype": "auto",
    "trust_remote_code": true,
    "local_files_only": true,
    "backend": "openai",
    "api_base_url": "http://127.0.0.1:8000/v1",
    "api_key": "EMPTY",
    "api_model": "Qwen-32B",
    "engine_kwargs": {}
  },
  "output_dir": "sarr_results",
  "dataset_paths": {
    "math500": "data/math500.jsonl",
    "aime24": "data/aime24.jsonl",
    "aime25": "data/aime25.parquet",
    "gpqa": "data/gpqa_diamond.jsonl",
    "gpqa_diamond": "data/gpqa_diamond.jsonl"
  },
  "generation": {
    "step_delimiters": ["\n\n"],
    "max_new_tokens_per_step": 256,
    "think_token_budget": 8192,
    "answer_token_budget": 2048,
    "final_answer_generator": "llm",
    "force_close_think_on_budget": true,
    "force_close_think_text": "\nWe are out of reliable reasoning budget. Stop reasoning now. Do not restart the solution after </think>. After </think>, give only the final answer using the strongest conclusion above; if uncertain, make the best concise guess.\n</think>\n\n"
  },
  "confidence": {
    "topk_entropy": 20,
    "percentile_normalization": true,
    "calibration_path": "sarr_results/calibration/aime25_slm_cdf.json",
    "allow_identity_normalizer": false,
    "smooth_window": 2,
    "delta": 0.55,
    "capture_slm_token_entropy": false
  },
  "startup": {
    "B_min": 2,
    "B_max": 5,
    "tau_start": 1
  },
  "stable": {
    "theta_s": 0.7,
    "tau_D": 1
  },
  "rollback": {
    "M_max": 5,
    "recovery_max_policy": "m_plus_1",
    "confidence_gated_recovery": true,
    "force_slm_after_recovery": true
  },
  "logging": {
    "save_step_records": true,
    "save_rollback_events": true,
    "save_transition_stats": true
  },
  "runtime": {
    "max_model_len": 16384,
    "reset_prefix_cache_after_problem": true
  }
}
