{
  "slm_model_path": "DeepSeek-R1-Distill-Qwen-1.5B",
  "llm_model_path": "Qwen-32B",
  "slm_tokenizer_path": null,
  "llm_tokenizer_path": null,
  "output_dir": "bpa_results",
  "dataset_paths": {
    "math500": "data/math500.jsonl",
    "aime24": "data/aime24.jsonl",
    "aime25": "data/aime25.parquet",
    "gpqa": "data/gpqa_diamond.jsonl",
    "gpqa_diamond": "data/gpqa_diamond.jsonl",
    "humaneval": "data/HumanEval.jsonl"
  },
  "slm_engine_kwargs": {
    "gpu_memory_utilization": 0.9
  },
  "llm_engine_kwargs": {
    "gpu_memory_utilization": 0.9
  },
  "slm_device": "cuda:0",
  "llm_device": "cuda:1",
  "trust_remote_code": true,
  "max_model_len": 16384,
  "enable_prefix_caching": true,
  "l0_topk": 10,
  "l0_margin_thresh": 0.4,
  "l0_entropy_thresh": 0.5,
  "rollout_length": 16,
  "l2_divergence_thresh": 0.15,
  "l2_text_jaccard_thresh": 0.4,
  "prompt_logprobs_topk": 20,
  "prompt_logprobs_sweep": [1, 5, 20],
  "score_missing_ratio_thresh": 0.2,
  "invalid_fallback": "skip",
  "max_step_tokens": 1024,
  "max_total_tokens": 16384,
  "max_llm_interventions": 8,
  "final_answer_max_tokens": 1024,
  "final_answer_chunk_tokens": 128,
  "repetition_ngram_size": 8,
  "repetition_ngram_threshold": 4,
  "slm_to_llm_flop_ratio": 0.05,
  "arbitration_tie_margin": 0.05,
  "cascade_mode": "bpa",
  "apply_arbitration": true,
  "collect_branch_logs": true
}
